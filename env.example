# ══════════════════════════════════════════════════
#  МедПланер — Переменные окружения
#  Скопируйте этот файл как .env и заполните значения
# ══════════════════════════════════════════════════

# ── Telegram ────────────────────────────────────────
# Получить у @BotFather в Telegram командой /newbot
TELEGRAM_BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL вашего Mini App (после деплоя на Netlify/Vercel)
MINIAPP_URL=https://your-miniapp.netlify.app

# ── Supabase ────────────────────────────────────────
# Получить на supabase.com → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ── Anthropic (Claude AI) ───────────────────────────
# Получить на console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google (Gmail + Google Calendar) ───────────────
# Получить на console.cloud.google.com
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Яндекс (Яндекс.Почта) ──────────────────────────
# Получить на oauth.yandex.ru
YANDEX_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
YANDEX_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Шифрование данных пациентов ─────────────────────
# Случайная строка ровно 32 символа — СОХРАНИТЕ НАДЁЖНО!
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Сервер ──────────────────────────────────────────
PORT=3000
APP_URL=https://your-server.onrender.com
ALLOWED_ORIGIN=https://your-miniapp.netlify.app
